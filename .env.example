# ==============================================================
# TakaCode - Variables d'environnement
# ==============================================================
# Copie ce fichier en .env.local et remplis les valeurs.
# 
# Utilise Supabase pour auth, BDD, et RLS.
# L'IA Review utilise un systeme de fallback multi-provider.
# ==============================================================

# --- Supabase (requis) ---
NEXT_PUBLIC_SUPABASE_URL=https://xxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...  # Utilise pour admin users et scripts

# --- Admin emails (requis) ---
# Emails des admins bootstrap (separes par des virgules)
TAKACODE_ADMIN_EMAILS=admin@example.com

# --- Site URL (optionnel) ---
# Utilise pour SEO (Open Graph, canonical). Defaut: https://takacode.vercel.app
NEXT_PUBLIC_SITE_URL=https://takacode.vercel.app

# --- Scripts ---
# Mot de passe du compte admin pour le script bootstrap-admin.mjs
SUPABASE_TAKACODE_PASSWORD=mon_mot_de_passe

# --- IA Review (optionnel sauf si AI_REVIEW_PROVIDER != huggingface) ---
# Provider principal : "openrouter" | "gemini" | "huggingface"
AI_REVIEW_PROVIDER=huggingface

# Ordre de fallback (separes par des virgules)
AI_REVIEW_FALLBACK=openrouter,gemini

# Cle API generique (utilisee par tous les providers si pas de cle specifique)
AI_REVIEW_API_KEY=

# Cle specifique OpenRouter (prioritaire sur AI_REVIEW_API_KEY)
AI_REVIEW_OPEN_ROUTER_API_KEY=sk-or-v1-...
# Variante acceptee (ancien nom)
AI_REVIEW_OPENROUTER_API_KEY=sk-or-v1-...

# Cle specifique Gemini (prioritaire sur AI_REVIEW_API_KEY)
AI_REVIEW_GEMINI_API_KEY=...

# Cle specifique HuggingFace (prioritaire sur AI_REVIEW_API_KEY)
# Pas requis: HuggingFace fonctionne sans cle (quota gratuit)
AI_REVIEW_HUGGINGFACE_API_KEY=

# Modele IA generique (defaut selon le provider si non specifie)
AI_REVIEW_MODEL=meta-llama/llama-3.2-3b-instruct

# Modele specifique par provider (optionnel, surcharge AI_REVIEW_MODEL)
# AI_REVIEW_OPENROUTER_MODEL=meta-llama/llama-3.2-3b-instruct,qwen/qwen-2.5-7b-instruct
# AI_REVIEW_GEMINI_MODEL=gemini-2.0-flash
# AI_REVIEW_HUGGINGFACE_MODEL=TinyLlama/TinyLlama-1.1B-Chat-v1.0
